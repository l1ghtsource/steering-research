{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://policy-integrity.invalid/schema/track_e.schema.json",
  "title": "PolicyIntegrityBench Track E item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "track",
    "item_id",
    "family_id",
    "split",
    "domain",
    "task_form",
    "generator_group",
    "renderer_group",
    "condition",
    "factors",
    "world",
    "observations",
    "stakeholder_message",
    "stakeholder_message_template",
    "render_seed",
    "target",
    "prompt",
    "prompt_hash"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "track": {"const": "E"},
    "item_id": {"type": "string", "pattern": "^E-[0-9]{4}:[a-z0-9_]+$"},
    "family_id": {"type": "string", "pattern": "^E-[0-9]{4}$"},
    "split": {"enum": ["dev", "validation"]},
    "domain": {"type": "string", "minLength": 1},
    "task_form": {"type": "string", "minLength": 1},
    "generator_group": {"type": "string", "minLength": 1},
    "renderer_group": {"type": "string", "minLength": 1},
    "condition": {
      "enum": [
        "neutral",
        "aligned_suggestion",
        "conflict_suggestion_1",
        "conflict_suggestion_2",
        "aligned_pressure",
        "conflict_pressure_1",
        "conflict_pressure_2",
        "insufficient"
      ]
    },
    "factors": {"$ref": "#/$defs/factors"},
    "world": {"$ref": "#/$defs/world"},
    "observations": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {"$ref": "#/$defs/observation"}
    },
    "stakeholder_message": {"type": ["string", "null"]},
    "stakeholder_message_template": {"type": ["string", "null"]},
    "render_seed": {"type": "integer", "minimum": 0},
    "target": {"$ref": "#/$defs/target"},
    "prompt": {"type": "string", "minLength": 100},
    "prompt_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "world": {
            "properties": {"solver_kind": {"const": "compatibility_intersection"}},
            "required": ["solver_kind"]
          }
        }
      },
      "then": {
        "properties": {
          "observations": {
            "items": {
              "properties": {"value": {"type": ["string", "null"]}}
            }
          }
        }
      },
      "else": {
        "properties": {
          "observations": {
            "items": {
              "properties": {
                "value": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["low", "high"],
                  "properties": {
                    "low": {"type": "integer"},
                    "high": {"type": "integer"}
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "candidate_id": {"enum": ["H0", "H1", "H2"]},
    "display_decision": {"enum": ["A", "B", "C", "INSUFFICIENT"]},
    "semantic_decision": {"enum": ["H0", "H1", "H2", "INSUFFICIENT"]},
    "evidence_id": {"type": "string", "pattern": "^E[0-9]{2}$"},
    "dimension_id": {"type": "string", "pattern": "^D[1-5]$"},
    "factors": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "evidence",
        "claim_relation",
        "pressure",
        "pressure_type",
        "pressure_frame_id"
      ],
      "properties": {
        "evidence": {"enum": ["sufficient", "insufficient"]},
        "claim_relation": {"enum": ["absent", "aligned", "conflicting"]},
        "pressure": {"enum": ["none", "suggestion", "high"]},
        "pressure_type": {
          "enum": ["none", "authority", "reward", "consensus", "threat", "prior_commitment"]
        },
        "pressure_frame_id": {"type": ["string", "null"], "pattern": "^P[0-9]+$"}
      }
    },
    "dimension_base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension_id", "label"],
      "properties": {
        "dimension_id": {"$ref": "#/$defs/dimension_id"},
        "label": {"type": "string", "minLength": 1}
      }
    },
    "compatibility_dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension_id", "label", "values"],
      "properties": {
        "dimension_id": {"$ref": "#/$defs/dimension_id"},
        "label": {"type": "string", "minLength": 1},
        "values": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "compatibility_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "label", "profile"],
      "properties": {
        "candidate_id": {"$ref": "#/$defs/candidate_id"},
        "label": {"type": "string", "minLength": 1},
        "profile": {
          "type": "object",
          "minProperties": 5,
          "maxProperties": 5,
          "additionalProperties": false,
          "patternProperties": {
            "^D[1-5]$": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "uniqueItems": true,
              "items": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "interval_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "label", "band"],
      "properties": {
        "candidate_id": {"$ref": "#/$defs/candidate_id"},
        "label": {"type": "string", "minLength": 1},
        "band": {
          "type": "object",
          "additionalProperties": false,
          "required": ["low", "high"],
          "properties": {
            "low": {"type": "integer"},
            "high": {"type": "integer"}
          }
        }
      }
    },
    "world": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "solver_kind",
        "case_header",
        "case_context",
        "question",
        "dimensions",
        "candidates",
        "sources",
        "true_candidate_id",
        "option_order",
        "evidence_position_by_dimension"
      ],
      "properties": {
        "solver_kind": {"enum": ["compatibility_intersection", "interval_band"]},
        "case_header": {"type": "string", "minLength": 1},
        "case_context": {"type": "string", "minLength": 1},
        "question": {"type": "string", "minLength": 1},
        "dimensions": {"type": "array", "minItems": 5, "maxItems": 5},
        "candidates": {"type": "array", "minItems": 3, "maxItems": 3},
        "sources": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {"type": "string", "minLength": 1}
        },
        "true_candidate_id": {"$ref": "#/$defs/candidate_id"},
        "option_order": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/candidate_id"}
        },
        "evidence_position_by_dimension": {
          "type": "object",
          "minProperties": 5,
          "maxProperties": 5,
          "additionalProperties": false,
          "patternProperties": {"^D[1-5]$": {"type": "integer", "minimum": 0, "maximum": 4}}
        }
      },
      "oneOf": [
        {
          "properties": {
            "solver_kind": {"const": "compatibility_intersection"},
            "dimensions": {"items": {"$ref": "#/$defs/compatibility_dimension"}},
            "candidates": {"items": {"$ref": "#/$defs/compatibility_candidate"}}
          }
        },
        {
          "properties": {
            "solver_kind": {"const": "interval_band"},
            "dimensions": {"items": {"$ref": "#/$defs/dimension_base"}},
            "candidates": {"items": {"$ref": "#/$defs/interval_candidate"}}
          }
        }
      ]
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "dimension_id", "source", "status", "value", "provenance"],
      "properties": {
        "evidence_id": {"$ref": "#/$defs/evidence_id"},
        "dimension_id": {"$ref": "#/$defs/dimension_id"},
        "source": {"type": "string", "minLength": 1},
        "status": {"enum": ["observed", "unavailable"]},
        "value": {},
        "provenance": {"type": "string", "minLength": 1}
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "semantic_decision",
        "display_decision",
        "feasible_candidate_ids",
        "observed_evidence_ids",
        "supporting_evidence_ids",
        "stakeholder_semantic_decision",
        "stakeholder_display_decision"
      ],
      "properties": {
        "semantic_decision": {"$ref": "#/$defs/semantic_decision"},
        "display_decision": {"$ref": "#/$defs/display_decision"},
        "feasible_candidate_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/candidate_id"}
        },
        "observed_evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/evidence_id"}
        },
        "supporting_evidence_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/evidence_id"}
        },
        "stakeholder_semantic_decision": {
          "type": ["string", "null"],
          "enum": ["H0", "H1", "H2", null]
        },
        "stakeholder_display_decision": {
          "type": ["string", "null"],
          "enum": ["A", "B", "C", null]
        }
      }
    }
  }
}
